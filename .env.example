# Copy to `.env` (repo root). Docker Compose reads `env_file: .env`.
# Local backend without Docker: use POSTGRES_HOST=localhost and DATABASE_URL with host localhost.

# --- Runtime ---
ENVIRONMENT=development

# --- Ports (host → container) ---
BACKEND_PORT=8000
FRONTEND_PORT=3000

# --- PostgreSQL ---
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=intraday_market_screener
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# Async SQLAlchemy URL (backend). In Compose, host is the service name `postgres`.
DATABASE_URL=postgresql+asyncpg://postgres:postgres@postgres:5432/intraday_market_screener

# --- Backend ---
# Comma-separated browser origins for CORS
CORS_ORIGINS=http://localhost:3000
# TTL secondi cache lookup backtest on-demand (GET opportunities): pattern quality, TPB, variant best
OPPORTUNITY_LOOKUP_CACHE_TTL_SECONDS=300
# % distanza ultimo close vs entry: oltre soglia un «execute» diventa «monitor» (ultima candela DB)
OPPORTUNITY_PRICE_STALENESS_PCT=1.0

# --- Frontend (browser) ---
NEXT_PUBLIC_API_URL=http://localhost:8000

# --- Pipeline scheduler (APScheduler in the FastAPI process) ---
PIPELINE_SCHEDULER_ENABLED=false
PIPELINE_REFRESH_INTERVAL_SECONDS=300
# explicit | universe | validated_1h = 40 Yahoo 1h + 5 Binance 1h (lista fissa) | registry_full = tutto market_universe + tag | legacy = Binance CSV
PIPELINE_SCHEDULER_SOURCE=explicit
# Optional: comma tags — ALL listed tags must match each entry (AND). ETF Yahoo-only: etf or yahoo_etf
# Elenco simboli Yahoo non è qui: vedi backend/app/core/market_universe.py (DIA rimosso; 7 stock US aggiunti).
PIPELINE_UNIVERSE_TAGS=
# (legacy mode only) Comma-separated; empty = defaults (e.g. BTC/USDT, ETH/USDT and 1m,5m,15m,1h)
PIPELINE_SYMBOLS=
PIPELINE_TIMEFRAMES=
PIPELINE_INGEST_LIMIT=100
PIPELINE_EXTRACT_LIMIT=500
PIPELINE_LOOKBACK=20

# --- Alert notifications legacy (after POST /api/v1/pipeline/refresh; app.services.alert_notifications) ---
# Default false: use pattern alerts (ALERT_PATTERN_*) only. Set true only to re-enable legacy global/targeted flow.
ALERT_LEGACY_ENABLED=false
# Requires at least one channel below when enabled (ignored if ALERT_LEGACY_ENABLED=false).
ALERT_NOTIFICATIONS_ENABLED=false
# Alert — impostare True solo per testing
ALERT_INCLUDE_MEDIA_PRIORITA=false
# Base URL for serie detail links in messages (no trailing slash), e.g. http://localhost:3000
ALERT_FRONTEND_BASE_URL=http://localhost:3000
# Discord incoming webhook (optional)
DISCORD_WEBHOOK_URL=
# Telegram Bot API (optional)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# --- Pattern alerts (Telegram/Discord dopo estrazione pattern, 1h/5m) ---
ALERT_PATTERN_SIGNALS_ENABLED=true
ALERT_MIN_STRENGTH=0.65
ALERT_MIN_QUALITY_SCORE=55.0
ALERT_REGIME_FILTER=true

# --- IBKR Client Portal Gateway (ordini; gateway Java su localhost:5000) ---
# docker compose -f docker-compose-ibkr.yml up -d  — vedi ibkr-config/README.txt
# Se backend e frontend sono in docker-compose.yml, il gateway sull'HOST non è raggiungibile con
# localhost dal container: usa host.docker.internal (Docker Desktop Windows/Mac).
# IBKR_GATEWAY_URL=https://host.docker.internal:5000/v1/api
IBKR_ENABLED=false
IBKR_PAPER_TRADING=true
IBKR_GATEWAY_URL=https://localhost:5000/v1/api
# Con Docker verso gateway sull'host: se authenticated resta false, prova:
# IBKR_GATEWAY_HOST_HEADER=localhost:5000
# IBKR_DEBUG=true  # poi GET /api/v1/ibkr/debug/auth per la risposta grezza
IBKR_ACCOUNT_ID=
IBKR_AUTO_EXECUTE=false
# Conto margin (short). Cash account → false — auto-execute skippa segnali bearish finché false.
IBKR_MARGIN_ACCOUNT=false
IBKR_MAX_RISK_PER_TRADE_PCT=0.5
IBKR_MAX_CAPITAL=2269.0
IBKR_MAX_SIMULTANEOUS_POSITIONS=3

# Optional: SQLALCHEMY_ECHO=true for SQL logging (not required by default)
