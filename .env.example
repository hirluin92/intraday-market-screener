# Copy to `.env` (repo root). Docker Compose reads `env_file: .env`.
# Local backend without Docker: use POSTGRES_HOST=localhost and DATABASE_URL with host localhost.

# --- Runtime ---
ENVIRONMENT=development

# --- Ports (host → container) ---
BACKEND_PORT=8000
FRONTEND_PORT=3000

# --- PostgreSQL ---
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=intraday_market_screener
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# Async SQLAlchemy URL (backend). In Compose, host is the service name `postgres`.
DATABASE_URL=postgresql+asyncpg://postgres:postgres@postgres:5432/intraday_market_screener

# --- Backend ---
# Comma-separated browser origins for CORS
CORS_ORIGINS=http://localhost:3000

# --- Frontend (browser) ---
NEXT_PUBLIC_API_URL=http://localhost:8000

# --- Pipeline scheduler (APScheduler in the FastAPI process) ---
PIPELINE_SCHEDULER_ENABLED=false
PIPELINE_REFRESH_INTERVAL_SECONDS=300
# universe = cross-market jobs from app/core/market_universe.py | legacy = Binance-only CSV below
PIPELINE_SCHEDULER_SOURCE=universe
# Optional: comma tags — ALL listed tags must match each entry (AND). ETF Yahoo-only: etf or yahoo_etf
PIPELINE_UNIVERSE_TAGS=
# (legacy mode only) Comma-separated; empty = defaults (e.g. BTC/USDT, ETH/USDT and 1m,5m,15m,1h)
PIPELINE_SYMBOLS=
PIPELINE_TIMEFRAMES=
PIPELINE_INGEST_LIMIT=100
PIPELINE_EXTRACT_LIMIT=500
PIPELINE_LOOKBACK=20

# --- Alert notifications (after POST /api/v1/pipeline/refresh) ---
# Requires at least one channel below when enabled.
ALERT_NOTIFICATIONS_ENABLED=false
# Base URL for serie detail links in messages (no trailing slash), e.g. http://localhost:3000
ALERT_FRONTEND_BASE_URL=
# Discord incoming webhook (optional)
DISCORD_WEBHOOK_URL=
# Telegram Bot API (optional)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Optional: SQLALCHEMY_ECHO=true for SQL logging (not required by default)
