# Copia questo file in `.env` nella root del repo (Compose legge `env_file: .env`).
# Senza un file `.env` reale, `docker compose` non applica le variabili attese.
# Per sviluppo locale senza Docker (uvicorn sulla macchina), usa invece
# POSTGRES_HOST=localhost e DATABASE_URL con host `localhost`.

ENVIRONMENT=development

BACKEND_PORT=8000
FRONTEND_PORT=3000

POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=intraday_market_screener
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

DATABASE_URL=postgresql+asyncpg://postgres:postgres@postgres:5432/intraday_market_screener

NEXT_PUBLIC_API_URL=http://localhost:8000
